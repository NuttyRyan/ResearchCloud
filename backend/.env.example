# ResearchCloud backend configuration (copy to .env and adjust).
# All variables are prefixed with RC_.

# Database (SQLite for dev; use a Postgres URL in deploy).
RC_DATABASE_URL=sqlite:///./researchcloud.db

# JWT signing secret. CHANGE THIS in production.
RC_SECRET_KEY=dev-insecure-secret-change-me

# Fernet key for encrypting stored Prism Central credentials.
# Leave unset in dev (derived from RC_SECRET_KEY). Set explicitly in production.
# RC_ENCRYPTION_KEY=

# Seeded admin login (dev convenience).
RC_ADMIN_USERNAME=admin
RC_ADMIN_PASSWORD=admin

# When true, always use the deterministic mock Nutanix provider (no live PC needed).
# Set to false to talk to real Prism Central endpoints stored in connections.
RC_FORCE_MOCK_NUTANIX=true
